model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-US
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation PBI_QueryOrder = ["DirectLake - saltroom_lakehouse"]

annotation __PBI_TimeIntelligenceEnabled = 1

annotation PBI_ProTooling = ["DirectLakeOnOneLakeInWeb","WebModelingEdit"]

ref table Date
ref table _Measures
ref table 'DQ Warnings'
ref table Client
ref table Purchases
ref table Timeclock
ref table Visits
ref table Service
ref table 'Purchase Item'
ref table 'Client Retention Snapshot'
ref table Staff
ref table 'Client Registration Date'

