{
  "name": "Salt Room Executive Theme",
  "dataColors": [
    "#8A6F55",
    "#C7A27C",
    "#6F8C7A",
    "#D7BFA6",
    "#9BA7A0",
    "#B76E5F",
    "#7A8FA6",
    "#E4D8C8"
  ],
  "background": "#F8F5EF",
  "foreground": "#30261F",
  "tableAccent": "#8A6F55",
  "textClasses": {
    "title": {
      "fontFace": "Segoe UI Semibold",
      "fontSize": 14,
      "color": "#30261F"
    },
    "label": {
      "fontFace": "Segoe UI",
      "fontSize": 10,
      "color": "#5C5148"
    },
    "callout": {
      "fontFace": "Segoe UI Semibold",
      "fontSize": 28,
      "color": "#30261F"
    }
  },
  "visualStyles": {
    "*": {
      "*": {
        "background": [
          {
            "show": true,
            "color": {
              "solid": {
                "color": "#FFFFFF"
              }
            },
            "transparency": 0
          }
        ],
        "border": [
          {
            "show": true,
            "color": {
              "solid": {
                "color": "#E5DACC"
              }
            },
            "radius": 6
          }
        ],
        "visualHeader": [
          {
            "show": false
          }
        ],
        "title": [
          {
            "show": true,
            "fontColor": {
              "solid": {
                "color": "#30261F"
              }
            },
            "fontSize": 11,
            "fontFamily": "Segoe UI Semibold"
          }
        ]
      }
    },
    "card": {
      "*": {
        "labels": [
          {
            "fontColor": {
              "solid": {
                "color": "#30261F"
              }
            },
            "fontSize": 22,
            "fontFamily": "Segoe UI Semibold"
          }
        ],
        "categoryLabels": [
          {
            "show": true,
            "fontColor": {
              "solid": {
                "color": "#6B5D52"
              }
            },
            "fontSize": 9
          }
        ]
      }
    },
    "slicer": {
      "*": {
        "items": [
          {
            "fontColor": {
              "solid": {
                "color": "#30261F"
              }
            },
            "textSize": 9
          }
        ],
        "header": [
          {
            "show": true,
            "fontColor": {
              "solid": {
                "color": "#30261F"
              }
            },
            "textSize": 9
          }
        ]
      }
    }
  }
}