{
  "bronze_schema": "bronze",
  "datasets": {
    "clients": {
      "load_type": "single_csv",
      "target_table": "clients",
      "path": "/wellnessliving/clients/wl_clients_full_20260420_v2.csv"
    },
    "visits": {
      "load_type": "multi_table_csv",
      "sources": [
        {
          "name": "attendance",
          "target_table": "visits_attendance",
          "path": "/wellnessliving/visits/wl_attendancewithPurchaseOption_full_20260420_v1.csv"
        },
        {
          "name": "booking_source",
          "target_table": "visits_booking_source",
          "path": "/wellnessliving/visits/wl_bookingsBySource_full_20260420_v1.csv"
        }
      ]
    },
    "timeclock": {
      "load_type": "single_csv",
      "target_table": "timeclock",
      "path": "/wellnessliving/timeclock/wl_timeclock_full_20260420_v1.csv"
    },
    "purchases": {
      "load_type": "multi_csv_union",
      "target_table": "purchases",
      "path_glob": "/wellnessliving/purchases/*.csv",
      "file_name_contains": "AllSales"
    }
  }
}
